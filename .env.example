# ─────────────────────────────────────────────────────────────────────────────
# Enterprise AI Workflow Agent — Environment Variables
# Copy this to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Exact model ID to use (claude-sonnet-4-20250514 is claude-sonnet-4-0 full ID)
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=workflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=workflow_db
# Full URL used by the backend container (hostname = postgres service name)
DATABASE_URL=postgresql://workflow:change_me_in_production@postgres:5432/workflow_db
# For local dev outside Docker:
# DATABASE_URL=postgresql://workflow:change_me_in_production@localhost:5432/workflow_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Backend ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
